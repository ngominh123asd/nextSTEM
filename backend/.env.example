# ── Environment ──────────────────────────────────────────────
# Set to "production" on Railway
ENVIRONMENT=development

# ── Database (Supabase) ──────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" pooler (port 6543) for app, "Session" pooler for migrations
# IMPORTANT: Use postgresql+asyncpg:// prefix (NOT postgres://)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ──────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → your-db → Details
# Use the rediss:// (with double s) URL for TLS
REDIS_URL=rediss://default:[password]@[endpoint].upstash.io:6379

# ── JWT ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS (add your Vercel domain) ────────────────────────────
# JSON array or comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# ── Railway (auto-injected, do NOT set manually) ─────────────
# PORT=8000

# ─────────────────────────────────────────────────────────────
# RAILWAY DASHBOARD — Environment Variables to set:
#   ENVIRONMENT            = production
#   DATABASE_URL           = postgresql+asyncpg://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres
#   REDIS_URL              = rediss://default:[pw]@[endpoint].upstash.io:6379
#   SECRET_KEY             = <generated-secret>
#   CORS_ORIGINS           = ["https://your-app.vercel.app"]
#   ACCESS_TOKEN_EXPIRE_MINUTES = 60
# ─────────────────────────────────────────────────────────────
